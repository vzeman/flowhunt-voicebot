# Optional local-development seed for a default SIP trunk when the dynamic
# Asterisk include file does not exist yet. Production trunks should be managed
# through the /sip-trunks API instead.
SIP_HOST=
SIP_USER=
SIP_PASSWORD=
PJSIP_BIND=0.0.0.0:5060
VOICEBOT_RUNTIME_ROLES=all
VOICEBOT_INTERNAL_AUTH_ENABLED=false
VOICEBOT_INTERNAL_AUTH_HEADER=X-FlowHunt-Internal-Key
# Comma-separated. Supported entries: secret, key_id:secret, or key_id:service:secret:scope1|scope2
VOICEBOT_INTERNAL_API_KEYS=
VOICEBOT_DASHBOARD_AUTH_ENABLED=false
VOICEBOT_DASHBOARD_DEV_LOGIN_ENABLED=false
VOICEBOT_DASHBOARD_USER_ID_HEADER=X-FlowHunt-User-Id
VOICEBOT_DASHBOARD_WORKSPACE_IDS_HEADER=X-FlowHunt-Workspace-Ids
VOICEBOT_DEFAULT_WORKSPACE_ID=
VOICEBOT_DEFAULT_VOICEBOT_ID=default
VOICEBOT_DEFAULT_VOICEBOT_DISPLAY_NAME=Default Voicebot
VOICEBOT_PUBLIC_SESSION_RATE_LIMIT_PER_MINUTE=60
VOICEBOT_PUBLIC_VOICEBOT_MAX_CONCURRENT_SESSIONS=100
VOICEBOT_PUBLIC_SDP_MAX_BYTES=131072
VOICEBOT_RELATIONAL_STORE_PROVIDER=
VOICEBOT_RELATIONAL_DATABASE_URL=/data/voicebot.sqlite3
VOICEBOT_CACHE_STORE_PROVIDER=
VOICEBOT_REDIS_URL=redis://redis:6379/0
VOICEBOT_OBJECT_STORAGE_BUCKET=
VOICEBOT_OBJECT_STORAGE_ENDPOINT=
VOICEBOT_OBJECT_STORAGE_REGION=
OPENAI_API_KEY=replace-with-openai-api-key
ANTHROPIC_API_KEY=
FLOWHUNT_API_KEY=
FLOWHUNT_WORKSPACE_ID=
FLOWHUNT_PROJECT_ID=
VOICEBOT_FLOWHUNT_BASE_URL=https://api.flowhunt.io
VOICEBOT_FLOWHUNT_TIMEOUT=30
VOICEBOT_FLOWHUNT_COMPLEX_BACKEND=project
FLOWHUNT_FLOW_ID=
VOICEBOT_FLOWHUNT_ISSUE_WAIT_SECONDS=45
VOICEBOT_FLOWHUNT_ISSUE_POLL_INTERVAL_SECONDS=2
VOICEBOT_FLOWHUNT_PROGRESS_UPDATE_SECONDS=12
VOICEBOT_FLOWHUNT_ISSUE_BACKGROUND_WAIT_SECONDS=600
VOICEBOT_FLOWHUNT_FLOW_WAIT_SECONDS=0
VOICEBOT_FLOWHUNT_FLOW_POLL_INTERVAL_SECONDS=3
VOICEBOT_SUBAGENT_PROVIDERS=[]
# Example:
# VOICEBOT_SUBAGENT_PROVIDERS=[{"kind":"langgraph_agent","label":"LangGraph agent","submit_url":"https://agent.example/submit","poll_url":"https://agent.example/poll","headers":{"Authorization":"Bearer token"},"required_metadata":["skill"]}]
VOICEBOT_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
VOICEBOT_TURN_COALESCE_WINDOW_MS=250
VOICEBOT_TURN_COALESCE_MAX_CHARS=80
VOICEBOT_LATENCY_BUDGET_ACK_SECONDS=2
VOICEBOT_LATENCY_BUDGET_FIRST_AUDIO_SECONDS=2.5
VOICEBOT_LATENCY_BUDGET_STT_SECONDS=1.5
VOICEBOT_LATENCY_BUDGET_AGENT_SECONDS=1.2
VOICEBOT_LATENCY_BUDGET_TTS_FIRST_AUDIO_SECONDS=0.8
VOICEBOT_LATENCY_BUDGET_DELEGATED_PROGRESS_SECONDS=12
VOICEBOT_EVENT_STORE_PROVIDER=json
VOICEBOT_EVENT_STORE_PATH=/data/events/events.jsonl
VOICEBOT_TRANSCRIPT_STORE_PROVIDER=jsonl
VOICEBOT_TRANSCRIPT_DIR=/data/transcripts
VOICEBOT_PROVIDER_CONFIG_STORE_PROVIDER=json
VOICEBOT_PROVIDER_CONFIG_STORE_PATH=/data/provider_config.json
VOICEBOT_SESSION_STORE_PROVIDER=json
VOICEBOT_SESSION_STORE_PATH=/data/voicebot_sessions.json
VOICEBOT_SESSION_LEASE_STORE_PROVIDER=json
VOICEBOT_SESSION_LEASE_STORE_PATH=/data/session_leases.json
VOICEBOT_AGENT_TASK_STORE_PROVIDER=json
VOICEBOT_AGENT_TASK_STORE_PATH=/data/agent_tasks.json
VOICEBOT_CALL_STATE_STORE_PROVIDER=json
VOICEBOT_CALL_STATE_STORE_PATH=/data/call_states.json
VOICEBOT_WORKER_REGISTRY_STORE_PROVIDER=json
VOICEBOT_WORKER_REGISTRY_STORE_PATH=/data/worker_registry.json
VOICEBOT_WORKER_QUEUE_STORE_PROVIDER=json
VOICEBOT_WORKER_QUEUE_STORE_PATH=/data/worker_queue.json
VOICEBOT_SIP_TRUNK_STORE_PROVIDER=json
VOICEBOT_SIP_TRUNK_REGISTRY_PATH=/data/sip_trunks.json
VOICEBOT_SIP_TRUNK_PJSIP_INCLUDE_PATH=/data/asterisk/pjsip-trunks.conf
VOICEBOT_SUBAGENT_TASK_STORE_PROVIDER=json
VOICEBOT_SUBAGENT_TASK_STORE_PATH=/data/subagent_tasks.json
VOICEBOT_AUDIO_ARTIFACT_STORE_PROVIDER=filesystem
VOICEBOT_SUBAGENT_TASK_POLL_LOOP_SECONDS=1
VOICEBOT_SUBAGENT_TASK_INITIAL_POLL_SECONDS=3
VOICEBOT_SUBAGENT_TASK_MAX_POLL_SECONDS=30
VOICEBOT_SUBAGENT_TASK_TIMEOUT_SECONDS=600
VOICEBOT_SUBAGENT_TASK_MAX_ATTEMPTS=100

VOICEBOT_OPENAI_BASE_URL=
VOICEBOT_STT_PROVIDER=openai
VOICEBOT_STT_API_KEY=
VOICEBOT_STT_BASE_URL=
VOICEBOT_STT_MODEL=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
VOICEBOT_OPENAI_STT_MODEL=gpt-4o-transcribe
VOICEBOT_LANGUAGE=en
VOICEBOT_STT_PROMPT=
VOICEBOT_STT_TIMEOUT_SECONDS=8
VOICEBOT_AGENT_MIN_TRANSCRIPT_CHARS=5
VOICEBOT_AGENT_MIN_TRANSCRIPT_TOKENS=2
VOICEBOT_DEBUG_AUDIO_CAPTURE=false
VOICEBOT_DEBUG_AUDIO_DIR=/data/debug-audio
VOICEBOT_START_THRESHOLD=0.020
VOICEBOT_STOP_THRESHOLD=0.010
VOICEBOT_VAD_START_MS=60
VOICEBOT_BARGE_IN_THRESHOLD=0.08
VOICEBOT_ECHO_TAIL_MS=300
VOICEBOT_SILENCE_MS=450
VOICEBOT_MAX_REPLY_CHARS=240
VOICEBOT_TTS_CHUNK_CHARS=90
VOICEBOT_MIN_SECONDS=0.35
VOICEBOT_DEFERRED_RESPONSE_WAIT_SECONDS=30
VOICEBOT_TTS_PROVIDER=openai
VOICEBOT_TTS_API_KEY=
VOICEBOT_TTS_BASE_URL=
VOICEBOT_TTS_MODEL=
VOICEBOT_TTS_TIMEOUT_SECONDS=8
ELEVENLABS_API_KEY=
VOICEBOT_TTS_VOICE=M1
VOICEBOT_OPENAI_TTS_MODEL=gpt-4o-mini-tts
VOICEBOT_OPENAI_TTS_VOICE=alloy
VOICEBOT_TTS_CACHE_ENABLED=true
VOICEBOT_TTS_CACHE_DIR=/data/tts-cache
VOICEBOT_CALL_RECORDING_ENABLED=true
VOICEBOT_CALL_RECORDING_SILENCE_THRESHOLD=0.003
VOICEBOT_AGENT_TASK_RESPONDED_EVENT_RETENTION=10000

VOICEBOT_CHAT_MODE=disabled
VOICEBOT_CHAT_SYSTEM_PROMPT=
VOICEBOT_CHAT_RESPONSE_PROMPT=When chat is enabled, write a visitor-readable Markdown chat message that is more detailed than the spoken answer. Use headings, bullets, and links when helpful. Do not duplicate the spoken wording.
VOICEBOT_CHAT_RICH_CONTENT_PROMPT=

VOICEBOT_AGENT_PROVIDER=openai-responses
VOICEBOT_AGENT_API_KEY=
# Use openai-chat-compatible with VOICEBOT_AGENT_OPENAI_BASE_URL for
# OpenRouter, Groq, Together, LM Studio, Ollama OpenAI-compatible gateways, etc.
VOICEBOT_AGENT_OPENAI_BASE_URL=
VOICEBOT_COMMUNICATION_AGENT_MODEL=
VOICEBOT_COMMUNICATION_AGENT_INTERVAL=
VOICEBOT_COMMUNICATION_AGENT_TIMEOUT=
VOICEBOT_COMMUNICATION_AGENT_MAX_OUTPUT_TOKENS=120
VOICEBOT_COMMUNICATION_AGENT_PROGRESS_ACK_DELAY_SECONDS=2.0
VOICEBOT_OPENAI_AGENT_MODEL=gpt-4.1-nano
VOICEBOT_OPENAI_AGENT_INTERVAL=0.2
VOICEBOT_OPENAI_AGENT_TIMEOUT=8
VOICEBOT_ANTHROPIC_AGENT_MODEL=claude-sonnet-4-20250514
VOICEBOT_ANTHROPIC_AGENT_INTERVAL=0.2
VOICEBOT_ANTHROPIC_AGENT_TIMEOUT=8
VOICEBOT_AGENT_HTTP_TIMEOUT=90
