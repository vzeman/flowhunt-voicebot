; Example Asterisk PJSIP configuration for the SIP trunk.
; Do not commit real passwords. Copy this to pjsip.conf or include it from
; pjsip.conf after replacing the placeholders.

[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0

[liveagent-reg]
type=registration
transport=transport-udp
outbound_auth=liveagent-auth
server_uri=sip:qla-prod-ec1-la-opensips-03.prod-ec1.live-agent.net
client_uri=sip:u262625_876@qla-prod-ec1-la-opensips-03.prod-ec1.live-agent.net
contact_user=u262625_876
endpoint=liveagent-endpoint
line=yes
retry_interval=60
forbidden_retry_interval=300
expiration=300

[liveagent-auth]
type=auth
auth_type=userpass
username=u262625_876
password=REPLACE_WITH_SIP_PASSWORD

[liveagent-aor]
type=aor
contact=sip:qla-prod-ec1-la-opensips-03.prod-ec1.live-agent.net

[liveagent-endpoint]
type=endpoint
transport=transport-udp
context=from-liveagent
disallow=all
allow=ulaw,alaw,slin
outbound_auth=liveagent-auth
aors=liveagent-aor
from_user=u262625_876
from_domain=qla-prod-ec1-la-opensips-03.prod-ec1.live-agent.net
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[liveagent-identify]
type=identify
endpoint=liveagent-endpoint
match=qla-prod-ec1-la-opensips-03.prod-ec1.live-agent.net
